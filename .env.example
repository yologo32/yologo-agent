# ========================
# Environment Variables
# ========================
# Copy file này thành .env và điền API key của bạn

# VNG Cloud AI Platform API Key
AI_PLATFORM_API_KEY=your_vng_cloud_api_key_here

# Tên bot (dùng để bot tự nhận diện khi bị mention)
# Điền đúng tên Zalo của tài khoản bot
BOT_NAME=TenBot

# Zalo UID của owner — chỉ những người này mới nhận DM hướng dẫn khi tag bot
# Để lấy UID: vào group → tag @Bot [myid] → bot sẽ DM UID cho bạn
# Nhiều owner thì cách nhau bằng dấu phẩy: BOT_OWNER_IDS=111,222,333
BOT_OWNER_IDS=

# (Tùy chọn) Giới hạn số lần bot reply mỗi phút (mặc định: 10)
RATE_LIMIT_PER_MINUTE=10

# Session Zalo (base64 encoded)
# Để trống khi chạy lần đầu — sau khi quét QR thành công,
# bot sẽ in ra giá trị này để bạn copy vào đây:
# ZALO_SESSION=eyJjb29raWUiOi4uLn0=
